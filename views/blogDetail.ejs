<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title><%= blog.title %></title>
  <style>
    .container { max-width: 800px; margin: 40px auto; padding: 0 20px; }
    .cover { width: 100%; height: 420px; object-fit: cover; border-radius: 8px; }
    .title { font-size: 32px; margin: 20px 0; color: #ff0000; }
    .meta { color: #ffffff; margin-bottom: 20px; }
    .content { white-space: pre-wrap; line-height: 1.8; color: #ff0000; }
    .back { display:inline-block; margin-top:20px; padding:8px 14px; background:#0088ff; color:#fff; border-radius:6px; text-decoration:none; }
  </style>
</head>
<body>
  <%- include('partials/nav',{user:user}) %>
  <div class="container">
    <img data-src="<%= blog.coverImageUrl %>" alt="<%= blog.title %>" class="cover" src="/images/default.png">
    <h1 class="title"><%= blog.title %></h1>
    <div class="meta">By <strong><%= blog.createdBy.fullName %></strong> • <%= new Date(blog.createdAt).toLocaleDateString() %></div>
    <div class="content"><%= blog.content %></div>
    <a href="/" class="back">← Back</a>
  </div>
  <%- include('partials/script') %>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const img = document.querySelector('.cover');
      if (img && img.dataset && img.dataset.src) {
        img.src = img.dataset.src;
      }
    });
  </script>
</body>
</html>