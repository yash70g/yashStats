<!DOCTYPE html>
<html lang="en">
<head>
   <%- include('partials/head') %>
   <title>Homepage</title>
   <style>
      .blogs-container {
         max-width: 1200px;
         margin: 0 auto;
         padding: 0 20px;
         margin-bottom: 50px;
      }
      .blogs-container h2 {
         font-size: 44px;
         margin-bottom: 30px;
         color: var(--neo-cyan);
         font-family: 'Orbitron', sans-serif;
         text-shadow: 0 6px 20px rgba(0,240,216,0.06);
         letter-spacing: 2px;
      }
      .no-blogs {
         text-align: center;
         padding: 40px;
         color: var(--muted);
         font-size: 18px;
      }
      .blogs-grid {
         display: grid;
         grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
         gap: 30px;
      }
      .blog-card {
         background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
         border-radius: 8px;
         overflow: hidden;
         box-shadow: 0 10px 30px rgba(2,6,23,0.6);
         transition: transform 0.28s, box-shadow 0.28s;
         border: 1px solid rgba(255,255,255,0.04);
      }
      .blog-card:hover {
         transform: translateY(-6px);
         box-shadow: 0 18px 40px rgba(2,6,23,0.7);
      }
      .blog-card img {
         width: 100%;
         height: 200px;
         object-fit: cover;
      }
      .blog-card-content {
         padding: 26px;
         color: #d9f7f0;
      }
      .blog-card h3 {
         font-size: 22px;
         margin-bottom: 14px;
         color: var(--neo-pink);
         min-height: 60px;
         display: -webkit-box;
         -webkit-line-clamp: 2;
         -webkit-box-orient: vertical;
         overflow: hidden;
         font-family: 'Share Tech Mono', monospace;
      }
      .blog-card .author {
         font-size: 14px;
         color: var(--muted);
         margin-bottom: 10px;
      }
      .blog-card .date {
         font-size: 12px;
         color: rgba(159,176,192,0.8);
         margin-bottom: 15px;
      }
      .blog-card .excerpt {
         font-size: 14px;
         color: #cfeee8;
         line-height: 1.6;
         min-height: 80px;
         display: -webkit-box;
         -webkit-line-clamp: 3;
         -webkit-box-orient: vertical;
         overflow: hidden;
      }
      .blog-card .view-link{
         display:inline-block;padding:8px 12px;background:rgb(255, 255, 255);color:#041018;border-radius:6px;text-decoration:none;font-weight:700;
      }
   </style>
</head>
<body>
    <%- include('partials/nav',{user:user}) %>
    

    <div class="blogs-container">
      <h2>Latest Stats</h2>
      
      <% if(blogs && blogs.length > 0) { %>
         <div class="blogs-grid">
            <% blogs.forEach(blog => { %>
               <div class="blog-card">
                  <img src="<%= blog.coverImageUrl %>" alt="<%= blog.title %>">
                  <div class="blog-card-content">
                     <h3><%= blog.title %></h3>
                     <div class="author">By <%= blog.createdBy.fullName %></div>
                     <div class="date"><%= new Date(blog.createdAt).toLocaleDateString() %></div>
                     <div class="excerpt"><%= blog.content.substring(0, 200) %></div>
                     <div style="margin-top:12px;">
                        <a href="/blog/<%= blog._id %>" class="view-link">View</a>
                     </div>
                  </div>
               </div>
            <% }); %>
         </div>
      <% } else { %>
         <div class="no-blogs">
            <h3 style="color: #999; margin-bottom: 10px;">No stats yet</h3>
         </div>
      <% } %>
    </div>

   <%- include('partials/script') %>
</body>
</html>